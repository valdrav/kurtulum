APP_NAME="Kurtulum İç ve Dış Ticaret"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_INSTALLED=false

# Production — portal.kurtulum.com
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://portal.kurtulum.com
# SESSION_SECURE_COOKIE=true
# SESSION_DOMAIN=
# HTTP_VERIFY_SSL=true

APP_LOCALE=tr
APP_FALLBACK_LOCALE=tr
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=10080
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Production HTTPS: SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# AI Features
AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# System Updates
UPDATE_CHECK_URL=https://api.exportflow.app/updates/check

# MarineTraffic AIS (ücretli, opsiyonel)
MARINETRAFFIC_API_KEY=

# Marinesia AIS — ücretsiz: https://marinesia.com/
MARINESIA_API_KEY=
VESSEL_TRACKING_REFRESH_MINUTES=15
VESSEL_TRACKING_CACHE_MINUTES=20

# TCMB kur senkron aralığı (dakika)
EXCHANGE_RATE_SYNC_MINUTES=15

# XAMPP/local ortamda SSL sertifika hatası varsa false yapın
HTTP_VERIFY_SSL=false
