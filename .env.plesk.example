APP_NAME="Kurtulum İç ve Dış Ticaret"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://portal.kurtulum.com
APP_INSTALLED=false

APP_LOCALE=tr
APP_FALLBACK_LOCALE=tr
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# Plesk MariaDB — Laravel surucusu: mysql
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=kurtulumportal_db
DB_USERNAME=kurtulumportal_user
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=10080
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

MAIL_MAILER=smtp
MAIL_HOST=mail.kurtulum.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@kurtulum.com"
MAIL_FROM_NAME="${APP_NAME}"

AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o-mini

UPDATE_CHECK_URL=https://api.exportflow.app/updates/check
MARINETRAFFIC_API_KEY=
MARINESIA_API_KEY=
VESSEL_TRACKING_REFRESH_MINUTES=15
VESSEL_TRACKING_CACHE_MINUTES=20
EXCHANGE_RATE_SYNC_MINUTES=15
HTTP_VERIFY_SSL=true
